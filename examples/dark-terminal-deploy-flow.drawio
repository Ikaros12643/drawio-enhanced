    <mxCell id="3" value="Developer Push" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;strokeWidth=1.5;fontSize=13;fontColor=#e2e8f0;fillColor=#1e293b;strokeColor=#3b82f6;" vertex="1" parent="1">
